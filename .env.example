# =============================================================================
# STELLAR x402 EXECUTOR — ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values before running.
# Never commit your real .env file to git.
# =============================================================================


# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------

# If Docker is unreachable, jobs fail with [ERROR] (no mock execution).

# Dev: if true, job containers are not auto-removed so you can inspect them in Docker Desktop.
# DOCKER_KEEP_CONTAINERS=false


# -----------------------------------------------------------------------------
# STELLAR NETWORK
# -----------------------------------------------------------------------------

STELLAR_NETWORK=TESTNET
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org


# -----------------------------------------------------------------------------
# WALLET KEYS
# Two separate accounts are required:
#   DEPLOYER — owns + manages the registry contract, funds setup
#   EXECUTOR — receives payments, runs jobs
# Generate both at: https://lab.stellar.org
# Fund testnet accounts at: https://lab.stellar.org/account/fund
# -----------------------------------------------------------------------------

DEPLOYER_PUBLIC_KEY=""
DEPLOYER_SECRET=""
EXECUTOR_PUBLIC_KEY=""
EXECUTOR_SECRET=""


# -----------------------------------------------------------------------------
# REGISTRY CONTRACT
# Deploy the Soroban registry contract first:
#   cd contracts/registry && stellar contract deploy ...
# Then paste the returned contract ID below.
#
# ⚠️  WARNING: If this is empty, ALL jobs will be refused by default.
#     To allow jobs without a registry (local dev only), set:
#     REGISTRY_BYPASS_DEV=true
#     Never set REGISTRY_BYPASS_DEV=true in production.
# -----------------------------------------------------------------------------

REGISTRY_CONTRACT_ID=""

# Default on-chain agent id for A2A / discovery (must match a row in the Soroban registry).
# AGENT_CARD_AGENT_ID=agent_402

# Local dev only — set to true if registry contract is not deployed yet.
# REGISTRY_BYPASS_DEV=false


# -----------------------------------------------------------------------------
# PUBLIC URL
# ⚠️  IMPORTANT: You MUST set this before running on any server or Docker.
# This is how other agents discover your API endpoint.
# Without it, /api/discovery and /.well-known/x402 will return a broken URL
# and no external agent will be able to find or call you.
#
# Example: PUBLIC_BASE_URL=https://your-server.com
# Local dev: PUBLIC_BASE_URL=http://localhost:8000
# No trailing slash.
# -----------------------------------------------------------------------------

PUBLIC_BASE_URL=


# -----------------------------------------------------------------------------
# x402 FACILITATOR (USDC payments — primary payment method)
# This is the official x402 v2 flow. Agents pay in USDC via the facilitator.
#
# Two facilitator options:
#
# Option A — Coinbase facilitator (testnet only, no API key needed):
#   X402_FACILITATOR_URL=https://x402.org/facilitator
#
# Option B — OpenZeppelin facilitator (testnet + mainnet, API key required):
#   Testnet API key: https://channels.openzeppelin.com/testnet/gen
#   Mainnet API key: https://channels.openzeppelin.com/gen
#   X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
#   X402_FACILITATOR_API_KEY=your_key_here
#
# To disable and only allow legacy XLM payments:
#   X402_FACILITATOR_ENABLED=false
# -----------------------------------------------------------------------------

X402_FACILITATOR_URL=https://x402.org/facilitator
# X402_FACILITATOR_API_KEY=
X402_FACILITATOR_ENABLED=true

# Price per job in USDC (decimal). Default: 0.01 USDC.
X402_PRICE=0.01

# If true, Gemini reviews stdout against the task (requires GEMINI_API_KEY); failures and parse errors fail the job.
# If false (default), validation uses explicit expected_* fields plus stdout hygiene only.
# AI_OUTPUT_VALIDATION=false

# Stellar network for x402 (defaults to STELLAR_NETWORK above).
# X402_STELLAR_NETWORK=TESTNET

# USDC contract address. Defaults are set automatically per network:
#   Testnet:  CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
#   Mainnet:  CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75
# Only set this if you are using a custom asset.
# X402_STELLAR_ASSET=


# -----------------------------------------------------------------------------
# LEGACY PAYMENT (fallback — XLM direct transfer)
# Agents can also pay by sending 0.05 native XLM directly to EXECUTOR_PUBLIC_KEY
# and passing the transaction hash in the X-Stellar-Payment-Tx header.
# This is the fallback path. USDC via facilitator is preferred.
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# IPFS / METADATA
# -----------------------------------------------------------------------------

# Gateway for resolving agent metadata CIDs (used in /api/discovery/resolved).
IPFS_GATEWAY=https://ipfs.io

# Pinata JWT for publishing agent metadata to IPFS.
# Get one at: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=


# -----------------------------------------------------------------------------
# EXTERNAL APIs
# -----------------------------------------------------------------------------

GEMINI_API_KEY=""
